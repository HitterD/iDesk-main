CREATE TABLE eform_signatures (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    eform_request_id UUID NOT NULL REFERENCES eform_requests(id) ON DELETE CASCADE,
    signer_id UUID NOT NULL REFERENCES users(id),
    signer_name VARCHAR(200) NOT NULL,
    signature_data TEXT NOT NULL,
    signer_role VARCHAR(50) NOT NULL,
    signed_at TIMESTAMP NOT NULL DEFAULT NOW()
);

-- Encrypted credentials
CREATE TABLE eform_credentials (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    eform_request_id UUID NOT NULL REFERENCES eform_requests(id) ON DELETE CASCADE,
    encrypted_username TEXT NOT NULL,
    encrypted_password TEXT NOT NULL,
    iv VARCHAR(64) NOT NULL,
    auth_tag VARCHAR(64) NOT NULL,
    provisioned_by_id UUID NOT NULL REFERENCES users(id),
    provisioned_at TIMESTAMP NOT NULL DEFAULT NOW(),
    access_created_at TIMESTAMP,
    access_expires_at TIMESTAMP,
    UNIQUE(eform_request_id)
);

-- Indexes
CREATE INDEX idx_eform_requests_status ON eform_requests(status);
CREATE INDEX idx_eform_requests_requester ON eform_requests(requester_id);
CREATE INDEX idx_eform_requests_approver ON eform_requests(current_approver_id);
CREATE INDEX idx_eform_approvals_request ON eform_approvals(eform_request_id);
