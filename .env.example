# ===========================================
# iDesk Environment Configuration
# ===========================================
# Copy this file to .env and update the values
# ⚠️ NEVER commit real secrets to version control!

# ===========================================
# Database (PostgreSQL via Docker)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password-here
DB_DATABASE=idesk_db
DB_LOGGING=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===========================================
# JWT Authentication
# ===========================================
# ⚠️ CRITICAL: Generate a strong secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-strong-64-char-secret-here
JWT_EXPIRES_IN=60m

# ===========================================
# Zoom Booking Configuration
# ===========================================
# Create a Server-to-Server OAuth App at https://marketplace.zoom.us
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ===========================================
# Telegram Bot Configuration
# ===========================================
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram Mode: 'polling' (development) or 'webhook' (production)
TELEGRAM_USE_WEBHOOK=false

# Webhook Configuration (only for production)
TELEGRAM_WEBHOOK_DOMAIN=https://api.yourapp.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# ===========================================
# Redis Configuration (for Bull Queue & Caching)
# ===========================================
# Set to 'true' to enable Redis-based queues (recommended for production)
REDIS_ENABLED=false

# Redis connection settings (only needed if REDIS_ENABLED=true)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/uploads

# ===========================================
# Email (SMTP) Configuration
# ===========================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM='iDesk Support <noreply@idesk.com>'

# ===========================================
# Application Settings
# ===========================================
PORT=5050
NODE_ENV=development

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:4050

# ===========================================
# Rate Limiting
# ===========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
PAGE_ACCESS_CACHE_TTL=300       # Cache TTL in seconds
PAGE_ACCESS_MAX_DENIALS=10      # Before lockout
PAGE_ACCESS_LOCKOUT_MINUTES=15  # Lockout duration

# ===========================================
# Google API Spreadsheet
# ===========================================
# Path to your Google Cloud service account JSON file
GOOGLE_CREDENTIALS_PATH=c:/iDesk/idesk-481813-271700b60e92.json