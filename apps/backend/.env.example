# ===========================================
# iDesk Backend Environment Configuration
# ===========================================

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=idesk_db
DB_LOGGING=false

# JWT Authentication (REQUIRED - must be at least 32 characters)
# Generate a new secret with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_SECRET_KEY_FOR_PRODUCTION_USE
JWT_EXPIRES_IN=60m

# ===========================================
# Telegram Bot Configuration
# ===========================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# Telegram Mode: 'polling' (development) or 'webhook' (production)
# Set to 'true' to use webhook mode
TELEGRAM_USE_WEBHOOK=false

# Webhook Configuration (only needed if TELEGRAM_USE_WEBHOOK=true)
TELEGRAM_WEBHOOK_DOMAIN=https://api.yourapp.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# ===========================================
# Redis Configuration (for Bull Queue)
# ===========================================
# Set to 'true' to enable Redis-based queues (recommended for production)
REDIS_ENABLED=false

# Redis connection settings (only needed if REDIS_ENABLED=true)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/uploads

# ===========================================
# Email (SMTP) Configuration
# ===========================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email
SMTP_PASS=your-password
SMTP_FROM='iDesk Support <noreply@idesk.com>'

# ===========================================
# Application Settings
# ===========================================
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# ===========================================
# Rate Limiting
# ===========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
PAGE_ACCESS_CACHE_TTL=300       # Cache TTL in seconds
PAGE_ACCESS_MAX_DENIALS=10      # Before lockout
PAGE_ACCESS_LOCKOUT_MINUTES=15  # Lockout duration

# ===========================================
# Google API Spreadsheet
# ===========================================
# Path to your Google Cloud service account JSON file
GOOGLE_CREDENTIALS_PATH=c:/iDesk/idesk-481813-271700b60e92.json

# ===========================================
# Web Push Notifications (VAPID)
# ===========================================
# Generate keys using: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@idesk.com
